# Provider selection: "openai" (any OpenAI-compatible API) or "bedrock"
RAG_LLM_PROVIDER=openai
RAG_EMBEDDING_PROVIDER=openai

# --- Option A: any OpenAI-compatible provider ---
RAG_LLM_BASE_URL=https://api.openai.com/v1
RAG_LLM_API_KEY=sk-your-key
RAG_LLM_MODEL=gpt-4o
RAG_LLM_SMALL_MODEL=gpt-4o-mini

RAG_EMBEDDING_BASE_URL=https://api.openai.com/v1
RAG_EMBEDDING_API_KEY=sk-your-key
RAG_EMBEDDING_MODEL=text-embedding-3-large
RAG_EMBEDDING_DIM=3072

# --- Option B: AWS Bedrock (set both providers above to "bedrock") ---
# Credentials come from the standard AWS chain (env vars, config file, or IAM role):
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
RAG_AWS_REGION=us-east-1
RAG_BEDROCK_LLM_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
RAG_BEDROCK_LLM_SMALL_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0
RAG_BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
# IMPORTANT with Titan v2: set RAG_EMBEDDING_DIM to 256, 512, or 1024
# RAG_EMBEDDING_DIM=1024

# Database
RAG_DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@localhost:5433/rag_db

# Gemini OCR
# RAG_GEMINI_API_KEY=AIzaSy...
# RAG_GEMINI_MODEL=gemini-2.5-flash

# Vector store
RAG_QDRANT_URL=http://localhost:6333
RAG_COLLECTION_NAME=rag_chunks

# Feature flags
RAG_ENABLE_CONTEXTUAL_ENRICHMENT=true
